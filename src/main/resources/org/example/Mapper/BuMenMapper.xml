<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Config 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.Mapper.BuMenMapper">


    <resultMap id="BuMen1" type="BuMen">
        <id property="b_id" column="b_id"></id>
        <result property="name" column="b_name"></result>
    </resultMap>
    <!--查询到结果后，包装到Bumen对象里面-->
    <select id="getBumen" resultMap="BuMen1">
        select *
        from BuMen
        where b_id=#{id};
    </select>
    <!--二级缓存-->

</mapper>